<?xml version="1.0"?>
<schema xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="urn:magento:framework:Setup/Declaration/Schema/etc/db_schema.xsd">
    <table name="muon_sms_retry_queue" resource="default" engine="innodb" comment="Muon SMS Retry Queue">
        <column xsi:type="int" name="entity_id" unsigned="true" nullable="false" identity="true" comment="Entity ID"/>
        <column xsi:type="text" name="message_payload" nullable="false" comment="Message Payload (JSON)"/>
        <column xsi:type="timestamp" name="scheduled_at" nullable="false" on_update="false" default="CURRENT_TIMESTAMP" comment="Scheduled At"/>
        <column xsi:type="timestamp" name="created_at" nullable="false" on_update="false" default="CURRENT_TIMESTAMP" comment="Created At"/>
        <constraint xsi:type="primary" referenceId="PRIMARY">
            <column name="entity_id"/>
        </constraint>
        <index referenceId="MUON_SMS_RETRY_QUEUE_SCHEDULED_AT" indexType="btree">
            <column name="scheduled_at"/>
        </index>
    </table>
</schema>
