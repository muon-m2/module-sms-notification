<?xml version="1.0"?>
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Config:etc/system_file.xsd">
    <system>
        <tab id="muon" translate="label" sortOrder="1000">
            <label>Muon Modules</label>
        </tab>
        <section id="sms_notification" translate="label" sortOrder="100" showInDefault="1" showInWebsite="1" showInStore="1">
            <label>SMS Notification</label>
            <tab>muon</tab>
            <resource>Muon_SMSNotification::general</resource>
            <group id="general" translate="label" sortOrder="10" showInDefault="1" showInWebsite="1" showInStore="1">
                <label>General Settings</label>
                <field id="enabled" translate="label" type="select" sortOrder="10" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Enable SMS Notifications</label>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                    <config_path>muon_sms_notification/general/enabled</config_path>
                </field>
                <field id="number_attempts" translate="label" type="text" sortOrder="20" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Number of Attempts</label>
                    <validate>validate-digits validate-greater-than-zero</validate>
                    <config_path>muon_sms_notification/general/number_attempts</config_path>
                </field>
                <field id="retry_delay" translate="label" type="text" sortOrder="25" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Retry Delay (seconds)</label>
                    <validate>validate-digits validate-zero-or-greater</validate>
                    <config_path>muon_sms_notification/general/retry_delay</config_path>
                </field>
                <field id="retry_batch_size" translate="label" type="text" sortOrder="27" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Retry Batch Size</label>
                    <validate>validate-digits validate-greater-than-zero</validate>
                    <comment>Maximum number of retry messages processed per cron run.</comment>
                    <config_path>muon_sms_notification/general/retry_batch_size</config_path>
                </field>
                <field id="rate_limit_per_minute" translate="label comment" type="text" sortOrder="28" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Rate Limit (per minute)</label>
                    <validate>validate-digits validate-zero-or-greater</validate>
                    <comment>Max SMS sent per minute per store. 0 = unlimited. Over-limit messages are deferred, not dropped.</comment>
                    <config_path>muon_sms_notification/general/rate_limit_per_minute</config_path>
                </field>
                <field id="max_length" translate="label comment" type="text" sortOrder="29" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Max Message Length</label>
                    <validate>validate-digits validate-zero-or-greater</validate>
                    <comment>Truncate outbound messages to this many characters. 0 = unlimited.</comment>
                    <config_path>muon_sms_notification/general/max_length</config_path>
                </field>
                <field id="send_to_phone" translate="label" type="text" sortOrder="30" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Send To Phone Number</label>
                    <backend_model>Muon\SMSNotification\Model\Config\Backend\Phone</backend_model>
                    <comment>Recipient in E.164 format, e.g. +14155552671.</comment>
                    <config_path>muon_sms_notification/general/send_to_phone</config_path>
                </field>
                <field id="transport_service" translate="label" type="select" sortOrder="40" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Transport Service</label>
                    <source_model>Muon\SMSNotification\Model\Config\Source\Transport</source_model>
                    <config_path>muon_sms_notification/general/transport_service</config_path>
                </field>
                <field id="queue_connection" translate="label" type="select" sortOrder="45" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Queue Connection</label>
                    <source_model>Muon\SMSNotification\Model\Config\Source\QueueConnection</source_model>
                    <config_path>muon_sms_notification/general/queue_connection</config_path>
                </field>
                <field id="test_sms" translate="label comment" type="button" sortOrder="50" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Test Configuration</label>
                    <frontend_model>Muon\SMSNotification\Block\Adminhtml\System\Config\TestSmsButton</frontend_model>
                    <comment>Sends a test SMS to the configured recipient using the saved transport settings.</comment>
                </field>
            </group>
            <group id="events" translate="label" sortOrder="15" showInDefault="1" showInWebsite="1" showInStore="1">
                <label>Event Notifications</label>
                <field id="order_enabled" translate="label" type="select" sortOrder="10" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Enable Order SMS</label>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                    <config_path>muon_sms_notification/events/order_enabled</config_path>
                </field>
                <field id="order_template" translate="label" type="textarea" sortOrder="20" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Order Notification Template</label>
                    <config_path>muon_sms_notification/events/order_template</config_path>
                    <depends>
                        <field id="order_enabled">1</field>
                    </depends>
                </field>
                <field id="customer_register_enabled" translate="label" type="select" sortOrder="30" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Enable Customer Registration SMS</label>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                    <config_path>muon_sms_notification/events/customer_register_enabled</config_path>
                </field>
                <field id="customer_register_template" translate="label" type="textarea" sortOrder="40" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Customer Registration Template</label>
                    <config_path>muon_sms_notification/events/customer_register_template</config_path>
                    <depends>
                        <field id="customer_register_enabled">1</field>
                    </depends>
                </field>
            </group>
            <group id="transport" translate="label" sortOrder="20" showInDefault="1" showInWebsite="1" showInStore="1">
                <label>Twilio Transport Settings</label>
                <field id="twilio_sid" translate="label" type="obscure" sortOrder="10" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Twilio SID</label>
                    <backend_model>Magento\Config\Model\Config\Backend\Encrypted</backend_model>
                    <config_path>muon_sms_notification/transport/twilio_sid</config_path>
                    <depends>
                        <field id="muon_sms_notification/general/transport_service">twilio</field>
                    </depends>
                </field>
                <field id="twilio_token" translate="label" type="obscure" sortOrder="20" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Twilio Token</label>
                    <backend_model>Magento\Config\Model\Config\Backend\Encrypted</backend_model>
                    <config_path>muon_sms_notification/transport/twilio_token</config_path>
                    <depends>
                        <field id="muon_sms_notification/general/transport_service">twilio</field>
                    </depends>
                </field>
                <field id="twilio_from" translate="label" type="text" sortOrder="30" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Twilio From Phone Number</label>
                    <config_path>muon_sms_notification/transport/twilio_send_from_phone</config_path>
                    <depends>
                        <field id="muon_sms_notification/general/transport_service">twilio</field>
                    </depends>
                </field>
            </group>
            <group id="vonage" translate="label" sortOrder="25" showInDefault="1" showInWebsite="1" showInStore="1">
                <label>Vonage Transport Settings</label>
                <field id="vonage_api_key" translate="label" type="obscure" sortOrder="10" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Vonage API Key</label>
                    <backend_model>Magento\Config\Model\Config\Backend\Encrypted</backend_model>
                    <config_path>muon_sms_notification/vonage/api_key</config_path>
                    <depends>
                        <field id="muon_sms_notification/general/transport_service">vonage</field>
                    </depends>
                </field>
                <field id="vonage_api_secret" translate="label" type="obscure" sortOrder="20" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Vonage API Secret</label>
                    <backend_model>Magento\Config\Model\Config\Backend\Encrypted</backend_model>
                    <config_path>muon_sms_notification/vonage/api_secret</config_path>
                    <depends>
                        <field id="muon_sms_notification/general/transport_service">vonage</field>
                    </depends>
                </field>
                <field id="vonage_from" translate="label" type="text" sortOrder="30" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Vonage Sender ID / Number</label>
                    <config_path>muon_sms_notification/vonage/from</config_path>
                    <depends>
                        <field id="muon_sms_notification/general/transport_service">vonage</field>
                    </depends>
                </field>
            </group>
        </section>
    </system>
</config>
